# Copy this file to `.env` in the project root and adjust values.
# .env is never committed to version control (see .gitignore).

# --- Django core ---
DJANGO_SECRET_KEY=change-this-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=UTC

# --- Session ---
SESSION_TIMEOUT_SECONDS=1800

# --- Upload limits ---
DATA_UPLOAD_MAX_MEMORY_SIZE=52428800
FILE_UPLOAD_MAX_MEMORY_SIZE=52428800

# --- Ollama (must be running locally: `ollama serve`) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
DEFAULT_EMBEDDING_MODEL=nomic-embed-text
DEFAULT_LLM_MODEL=qwen3:14b-instruct

# --- Vector database ---
VECTOR_DB_BACKEND=chromadb

# --- OCR (Windows paths - adjust to your install locations) ---
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=C:\poppler\Library\bin

# --- Chunking defaults ---
DEFAULT_CHUNK_SIZE_TOKENS=1024
DEFAULT_CHUNK_OVERLAP_TOKENS=150
DEFAULT_CHUNKING_STRATEGY=recursive
